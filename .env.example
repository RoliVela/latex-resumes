# Server-side secrets (never expose to the browser)

# NVIDIA API key from https://build.nvidia.com/settings/api-keys
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare Turnstile secret key (server-side verification)
TURNSTILE_SECRET_KEY=0x0000000000000000000000000000000000000000

# Upstash Redis REST credentials for rate limiting (recommended)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# OR use Vercel KV instead (leave Upstash blank if using Vercel KV)
VERCEL_KV_REST_API_URL=
VERCEL_KV_REST_API_TOKEN=

# Client-safe public values (may appear in HTML)
# Turnstile site key for the widget in index.html data-sitekey attribute
TURNSTILE_SITE_KEY=0x0000000000000000000000000000000000000000

# EmailJS public keys (already public in index.html / script.js)
# EMAILJS_PUBLIC_KEY=z0Vx2xEyRH8wEg62N
